{
  "rewrites": [
    {
      "source": "/",
      "destination": "/landing.html"
    },
    {
      "source": "/register",
      "destination": "/auth.html"
    },
    {
      "source": "/login",
      "destination": "/auth.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/billing",
      "destination": "/billing.html"
    },
    {
      "source": "/loja",
      "destination": "/storefront.html"
    },
    {
      "source": "/setup",
      "destination": "/setup-firestore.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/docs",
      "destination": "https://github.com/seu-usuario/mercadohub-saas/tree/main/docs"
    }
  ]
}
